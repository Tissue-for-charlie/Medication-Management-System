from datetime import datetime
from pydantic import BaseModel, Field
from typing import Optional, List

# 基础供应商模型
class SupplierBase(BaseModel):
    supplier_name: str = Field(..., min_length=1, max_length=100, description="供应商名")
    contact: str = Field(..., min_length=1, max_length=20, description="联系方式")
    address: str = Field(..., min_length=1, max_length=200, description="地址")
    notes: Optional[str] = Field(None, description="备注")

# 新增供应商（不含ID、时间）
class SupplierCreate(SupplierBase):
    pass

# 更新供应商
class SupplierUpdate(SupplierBase):
    pass

# 供应商响应（含ID、时间）
class SupplierResponse(SupplierBase):
    id: int
    created_at: datetime
    updated_at: datetime

    class Config:
        orm_mode = True

# 分页响应模型
class PaginatedResponse(BaseModel):
    total: int
    page: int
    page_size: int
    data: List[SupplierResponse]